flowchart LR
    subgraph Source["Data Sources"]
        A[Raw Insurance Datasets<br/>CSV or Database]
    end

    subgraph EDA["Exploratory Data Analysis"]
        B[eda_main.py]
        C[EDA Plots & Summaries<br/>Outliers and Distributions]
    end

    subgraph Preprocess["Preprocessing Utilities"]
        D[utils/preprocessing.py]
        E[Cleaned & Engineered<br/>Features Dataset]
    end

    subgraph Training["Model Training"]
        F[models/train_models.py]
        G[Trained Models<br/>Logistic, RF, XGB]
    end

    subgraph Evaluation["Model Evaluation"]
        H[evaluation/evaluate_models.py]
        I[Metrics Tables<br/>CSV or Markdown]
        J[Comparison Plots<br/>ROC, PR, Accuracy]
    end

    subgraph Artifacts["Artifacts for Report"]
        K[Saved Models<br/>Joblib or Pickle Files]
        L[Figures<br/>PNG from EDA and Evaluation]
        M[Mermaid Diagrams<br/>MMD Files in diagrams]
        N[Final Report<br/>report.md and PDF]
    end

